# ============================================
# AI Agent — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === LLM Providers ===

# Groq API Key (PRIMARY — get free at https://console.groq.com)
GROQ_API_KEY=your_groq_key_here

# OpenRouter API Key (FALLBACK — get free at https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_key_here

# Default LLM model (Groq for reliability)
DEFAULT_MODEL=groq::meta-llama/llama-4-scout-17b-16e-instruct

# Max reasoning iterations before forcing a final answer
MAX_ITERATIONS=6

# === Database Configuration ===

# SQLite database path (local fallback — always works)
DATABASE_PATH=data/memory.db

# Supabase PostgreSQL (optional — for cloud-persistent memory)
# Get free at: https://supabase.com
SUPABASE_URL=
SUPABASE_KEY=

# Redis (optional — for response caching)
# Get free at: https://redis.io/try-free
REDIS_URL=

# === Vector Database (RAG) — Choose one ===

# Pinecone (cloud vector search)
# Get free at: https://app.pinecone.io
PINECONE_API_KEY=

# Weaviate (cloud vector search)
# Get free at: https://console.weaviate.cloud
WEAVIATE_URL=
WEAVIATE_API_KEY=

# Qdrant (cloud vector search)
# Get free at: https://cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=

# === Auditor ===

# Model for the auditor (quality + fact check)
AUDITOR_MODEL=google/gemini-2.0-flash-exp:free
AUDITOR_ENABLED=true

# === MCP (Model Context Protocol) ===
# API keys for MCP servers (optional — can also be entered in the app UI)

# Brave Search (for brave-search MCP server)
# Get free at: https://brave.com/search/api/
BRAVE_API_KEY=

# GitHub Personal Access Token (for github MCP server)
GITHUB_TOKEN=
