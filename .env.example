# ============================================
# AI Agent — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# OpenRouter API Key (get one free at https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_key_here

# Default LLM model to use
DEFAULT_MODEL=x-ai/grok-4.1-fast

# Max reasoning iterations before forcing a final answer
MAX_ITERATIONS=10

# === Database Configuration ===

# SQLite database path (local fallback — always works)
DATABASE_PATH=data/memory.db

# Supabase PostgreSQL (optional — for cloud-persistent memory)
# Get free at: https://supabase.com
SUPABASE_URL=
SUPABASE_KEY=

# Redis (optional — for response caching)
# Get free at: https://redis.io/try-free
REDIS_URL=

# Pinecone (optional — for RAG document search)
# Get free at: https://app.pinecone.io
PINECONE_API_KEY=
